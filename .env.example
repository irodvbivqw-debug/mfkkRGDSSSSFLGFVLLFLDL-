# Example .env for local development — do NOT commit real secrets to git.
# Copy this file to .env locally and fill values for development only.

BOT_TOKEN=your-telegram-bot-token-here
OPERATORS_GROUP_ID=-100xxxxxxxxxx
CHANNEL_ID=-100xxxxxxxxxx
CHANNEL_INVITE_LINK=https://telegram.me/your_channel
SUPPORT_USERNAME=@your_support_username
ADMIN_IDS=123456789
BOT_LINK=https://telegram.me/your_bot_link
ENV=development
